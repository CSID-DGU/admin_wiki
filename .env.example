# Copy to .env and fill in WIKI_GITHUB_TOKEN before starting the stack.
WIKI_REPOSITORY_URL=https://github.com/CSID-DGU/admin_wiki.git
WIKI_BRANCH=main
WIKI_SYNC_INTERVAL_SECONDS=60
# This repository is private: use a fine-grained token with read-only Contents access.
WIKI_GIT_USERNAME=x-access-token
WIKI_GITHUB_TOKEN=
WIKI_BIND_ADDRESS=0.0.0.0
WIKI_PORT=30097
