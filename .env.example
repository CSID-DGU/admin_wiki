# Copy to .env only when the defaults need to change.
WIKI_REPOSITORY_URL=https://github.com/CSID-DGU/admin_infra_server.git
WIKI_BRANCH=main
WIKI_SYNC_INTERVAL_SECONDS=60
# Private repository only: use a fine-grained token with read-only Contents access.
WIKI_GIT_USERNAME=x-access-token
WIKI_GITHUB_TOKEN=
WIKI_BIND_ADDRESS=0.0.0.0
WIKI_PORT=30097
